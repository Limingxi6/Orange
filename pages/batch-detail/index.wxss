.page {
  min-height: 100vh;
  padding: 24rpx;
  background: #F5F5F5;
}

.info-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.card-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #EEEEEE;
}

.info-row {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  font-size: 28rpx;
}

.info-row:last-child {
  margin-bottom: 0;
}

.info-label {
  width: 160rpx;
  color: #999;
  flex-shrink: 0;
}

.info-value {
  flex: 1;
  color: #333;
}

.info-row--tap {
  padding: 12rpx 0;
  border-radius: 8rpx;
  transition: background 0.15s;
}

.info-row--tap:active {
  background: #F5F5F5;
}

.stage-value {
  display: flex;
  align-items: center;
  justify-content: space-between;
  color: #FF8C00;
  font-weight: 500;
}

.stage-arrow {
  font-size: 36rpx;
  color: #CCC;
  margin-left: 8rpx;
}

.status-tag {
  display: inline-block;
  padding: 6rpx 20rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
}

.status-planting {
  background: #FFF3E0;
  color: #FF8C00;
}

.status-harvested {
  background: #E3F2FD;
  color: #2196F3;
}

.action-row {
  display: flex;
  justify-content: space-between;
  gap: 24rpx;
  margin-bottom: 24rpx;
}

.action-btn {
  flex: 1;
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx 16rpx;
  text-align: center;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
  border: 2rpx solid #FF8C00;
}

.action-icon {
  display: block;
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.action-text {
  font-size: 26rpx;
  color: #FF8C00;
  font-weight: 500;
}

.log-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
}

.log-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.log-item {
  padding: 20rpx;
  background: #F8F8F8;
  border-radius: 12rpx;
  font-size: 26rpx;
}

.log-date {
  color: #999;
  font-size: 24rpx;
  margin-bottom: 8rpx;
}

.log-content {
  color: #333;
  line-height: 1.5;
  margin-bottom: 8rpx;
}

.log-type {
  color: #FF8C00;
  font-size: 24rpx;
}
