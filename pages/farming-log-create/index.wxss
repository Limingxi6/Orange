.page {
  min-height: 100vh;
  background: #F5F5F5;
  padding: 24rpx;
}

.form-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx 36rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.08);
}

.field-group {
  margin-bottom: 28rpx;
}

.field-label {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 12rpx;
  padding-left: 4rpx;
}

.field-hint {
  font-size: 24rpx;
  font-weight: 400;
  color: #999;
}

.field-wrap {
  background: #F7F7F7;
  border-radius: 16rpx;
  overflow: hidden;
}

/* ====== Picker 选择器样式 ====== */
.picker-field {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  min-height: 96rpx;
  box-sizing: border-box;
}

.picker-text {
  display: flex;
  align-items: center;
}

.picker-icon {
  margin-right: 12rpx;
}

.picker-value {
  font-size: 28rpx;
  color: #333;
}

.picker-placeholder {
  font-size: 28rpx;
  color: #c8c9cc;
}

/* ====== 提交按钮 ====== */
.submit-btn {
  margin-top: 48rpx;
  height: 96rpx !important;
  font-size: 32rpx !important;
}
