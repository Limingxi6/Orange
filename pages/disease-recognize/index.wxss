.page {
  min-height: 100vh;
  padding: 32rpx;
  padding-bottom: 60rpx;
  background: #F5F5F5;
}

/* ====== 图片选择区 ====== */
.upload-wrapper {
  margin-bottom: 32rpx;
}

.upload-box {
  background: #fff;
  border: 4rpx dashed #FF8C00;
  border-radius: 24rpx;
  padding: 48rpx 24rpx;
  display: flex;
  justify-content: center;
  align-items: center;
}

.preview-box {
  position: relative;
  width: 100%;
  border-radius: 24rpx;
  overflow: hidden;
  background: #fff;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.08);
}

.preview-img {
  width: 100%;
  height: 480rpx;
  display: block;
}

.preview-remove {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
}

/* ====== 按钮 ====== */
.action-btn {
  margin-bottom: 8rpx;
}

.btn-icon {
  margin-right: 10rpx;
}

/* ====== 识别结果 ====== */
.result-section {
  animation: fadeUp 0.35s ease-out;
}

@keyframes fadeUp {
  from { opacity: 0; transform: translateY(30rpx); }
  to   { opacity: 1; transform: translateY(0); }
}

.result-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 36rpx;
  box-shadow: 0 4rpx 24rpx rgba(255, 140, 0, 0.10);
  border-left: 10rpx solid #FF8C00;
  margin-bottom: 32rpx;
}

.result-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 28rpx;
}

.result-label {
  font-size: 38rpx;
  font-weight: 700;
  color: #222;
}

/* 指标行 */
.metric-row {
  display: flex;
  align-items: center;
  background: #FAFAFA;
  border-radius: 16rpx;
  padding: 24rpx 0;
  margin-bottom: 28rpx;
}

.metric-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.metric-value {
  font-size: 40rpx;
  font-weight: 700;
  color: #333;
}

.metric-value.highlight {
  color: #FF8C00;
}

.metric-title {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

.metric-divider {
  width: 2rpx;
  height: 64rpx;
  background: #E0E0E0;
}

/* 建议 */
.advice-box {
  display: flex;
  align-items: flex-start;
  padding: 24rpx;
  background: #FFF7ED;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
}

.advice-icon {
  margin-right: 16rpx;
  margin-top: 4rpx;
  flex-shrink: 0;
}

.advice-text {
  font-size: 28rpx;
  color: #333;
  line-height: 1.7;
}

/* 复核提示 */
.review-bar {
  border-radius: 12rpx;
  overflow: hidden;
}

/* 保存按钮 */
.save-btn {
  margin-top: 8rpx;
}

/* ====== 空状态提示 ====== */
.tips {
  display: flex;
  align-items: flex-start;
  padding: 32rpx;
  margin-top: 24rpx;
}

.tips-text {
  font-size: 26rpx;
  color: #bbb;
  margin-left: 12rpx;
  line-height: 1.6;
}
