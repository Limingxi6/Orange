<view class="login-page">
  <view class="logo-area">
    <view class="logo-circle">
      <text class="logo-text">橘</text>
    </view>
    <text class="app-name">橘源通</text>
    <text class="app-desc">柑橘全产业链溯源平台</text>
  </view>

  <view class="form-card">
    <view class="field-wrap">
      <van-field
        value="{{ phone }}"
        type="number"
        maxlength="11"
        placeholder="请输入手机号"
        border="{{ false }}"
        bind:change="onPhoneChange"
        left-icon="phone-o"
      />
    </view>

    <view class="field-wrap code-field">
      <van-field
        value="{{ code }}"
        type="number"
        maxlength="6"
        placeholder="请输入验证码"
        border="{{ false }}"
        bind:change="onCodeChange"
        left-icon="shield-o"
      />
      <view class="code-btn {{ countdown > 0 ? 'disabled' : '' }}" bindtap="onSendCode">
        <text>{{ countdown > 0 ? countdown + 's' : '获取验证码' }}</text>
      </view>
    </view>

    <van-button
      type="warning"
      block
      round
      color="#FF8C00"
      loading="{{ logging }}"
      disabled="{{ !canLogin }}"
      bind:click="onLogin"
      custom-class="login-btn"
    >
      登录
    </van-button>

    <view class="test-hint">
      <text>测试账号：13800000000 / 123456</text>
    </view>

    <van-button
      wx:if="{{isDev}}"
      plain
      round
      size="small"
      color="#999"
      custom-class="quick-btn"
      loading="{{logging}}"
      bind:click="onQuickLogin"
    >开发调试：一键登录</van-button>
  </view>
</view>

<van-toast id="van-toast" />
