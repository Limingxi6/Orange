.login-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #FF8C00 0%, #FFA940 40%, #F5F5F5 60%);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 48rpx;
}

.logo-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 160rpx;
  margin-bottom: 80rpx;
}

.logo-circle {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
}

.logo-text {
  font-size: 72rpx;
  color: #fff;
  font-weight: bold;
}

.app-name {
  font-size: 44rpx;
  color: #fff;
  font-weight: bold;
  margin-bottom: 12rpx;
}

.app-desc {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
}

.form-card {
  width: 100%;
  background: #fff;
  border-radius: 24rpx;
  padding: 48rpx 36rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.08);
}

.field-wrap {
  background: #F7F7F7;
  border-radius: 16rpx;
  margin-bottom: 28rpx;
  overflow: hidden;
}

.code-field {
  display: flex;
  align-items: center;
}

.code-field .van-field {
  flex: 1;
}

.code-btn {
  flex-shrink: 0;
  padding: 0 24rpx;
  height: 100%;
  display: flex;
  align-items: center;
  border-left: 2rpx solid #E8E8E8;
}

.code-btn text {
  font-size: 26rpx;
  color: #FF8C00;
  white-space: nowrap;
}

.code-btn.disabled text {
  color: #ccc;
}

.login-btn {
  margin-top: 16rpx;
  height: 96rpx !important;
  font-size: 32rpx !important;
}

.test-hint {
  text-align: center;
  margin-top: 32rpx;
}

.test-hint text {
  font-size: 24rpx;
  color: #999;
}

.quick-btn {
  margin-top: 24rpx;
}
