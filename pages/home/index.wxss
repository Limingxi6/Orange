.container {
  padding: 24rpx;
  padding-bottom: 48rpx;
}

/* 天气卡片 */
.weather-card {
  background: linear-gradient(135deg, #FF8C00 0%, #FFA726 100%);
  border-radius: 20rpx;
  padding: 40rpx;
  margin-bottom: 24rpx;
  color: #fff;
}

.weather-card--error {
  background: linear-gradient(135deg, #BDBDBD 0%, #E0E0E0 100%);
}

.weather-main {
  display: flex;
  align-items: baseline;
  margin-bottom: 16rpx;
}

.weather-condition {
  font-size: 32rpx;
  margin-right: 20rpx;
}

.weather-temp {
  font-size: 56rpx;
  font-weight: 600;
}

.weather-detail {
  font-size: 24rpx;
  opacity: 0.9;
}

.weather-item {
  margin-right: 12rpx;
}

.weather-retry {
  text-decoration: underline;
}

/* 风险通知 */
.risk-notice {
  margin-bottom: 32rpx;
  border-radius: 12rpx;
  overflow: hidden;
}

/* 快捷功能 */
.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
}

.quick-grid {
  margin-bottom: 32rpx;
}

/* 批次列表 */
.batch-group {
  margin-bottom: 24rpx;
}
