# ============================================
# 橘源通后端配置文件
# 复制此文件为 .env 并修改配置值
# ============================================

# ---------- 应用配置 ----------
PORT=8080
NODE_ENV=development

# ---------- 数据库配置 ----------
# MySQL 连接字符串
DATABASE_URL="mysql://root:password@localhost:3306/orange_db"

# ---------- Redis 配置 ----------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ---------- JWT 配置 ----------
# JWT 密钥（生产环境请使用强密钥，至少 32 位）
JWT_SECRET=your-super-secret-jwt-key-change-in-production
# JWT 过期时间（支持 s/m/h/d，如 7d 表示 7 天）
JWT_EXPIRES_IN=7d

# ---------- 文件上传配置 ----------
# 上传模式：local（本地存储）| minio（MinIO 对象存储）| cos（腾讯云 COS）
UPLOAD_MODE=local
# 本地上传目录（UPLOAD_MODE=local 时生效）
LOCAL_UPLOAD_DIR=./uploads

# ---------- MinIO 配置（UPLOAD_MODE=minio 时必填）----------
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=orange
MINIO_USE_SSL=false
