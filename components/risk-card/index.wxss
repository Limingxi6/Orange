.risk-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
  border-left: 8rpx solid;
}

.risk-low {
  border-left-color: #4CAF50;
}

.risk-medium {
  border-left-color: #FF8C00;
}

.risk-high {
  border-left-color: #F44336;
}

.risk-header {
  margin-bottom: 16rpx;
}

.risk-level {
  font-size: 30rpx;
  font-weight: 600;
}

.risk-low .risk-level {
  color: #4CAF50;
}

.risk-medium .risk-level {
  color: #FF8C00;
}

.risk-high .risk-level {
  color: #F44336;
}

.risk-body {
  font-size: 26rpx;
  color: #666;
}

.risk-item {
  margin-bottom: 12rpx;
  line-height: 1.6;
}

.risk-item:last-child {
  margin-bottom: 0;
}

.risk-label {
  color: #999;
  margin-right: 8rpx;
}

.risk-value {
  color: #333;
}
