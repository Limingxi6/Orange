.batch-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.batch-header {
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #EEEEEE;
}

.batch-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  flex: 1;
}

.batch-status {
  padding: 6rpx 20rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  flex-shrink: 0;
}

.status-normal {
  background: #E8F5E9;
  color: #4CAF50;
}

.status-pending {
  background: #FFF3E0;
  color: #FF8C00;
}

.status-abnormal {
  background: #FFEBEE;
  color: #F44336;
}

.status-done {
  background: #E3F2FD;
  color: #2196F3;
}

.batch-body {
  font-size: 26rpx;
}

.batch-row {
  margin-bottom: 12rpx;
  line-height: 1.6;
}

.batch-row:last-child {
  margin-bottom: 0;
}

.batch-label {
  color: #999;
  margin-right: 8rpx;
}

.batch-value {
  color: #333;
}

.flex-between {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
