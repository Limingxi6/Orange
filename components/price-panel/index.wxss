.price-panel {
  background: #fff;
  border-radius: 20rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(255, 140, 0, 0.10);
  border: 1rpx solid rgba(255, 140, 0, 0.18);
}

/* 头部 */
.panel-header {
  margin-bottom: 28rpx;
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.grade-value {
  font-size: 40rpx;
  font-weight: 700;
  color: #FF8C00;
}

.variety-text {
  display: inline-block;
  font-size: 26rpx;
  color: #999;
  margin-left: 16rpx;
}

/* 价格 */
.price-block {
  margin-bottom: 24rpx;
}

.price-label {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.price-row {
  display: flex;
  align-items: baseline;
}

.price-num {
  font-size: 40rpx;
  font-weight: 700;
  color: #FF8C00;
}

.price-num.wholesale {
  color: #42A5F5;
}

.price-unit {
  font-size: 24rpx;
  color: #999;
}

.price-sep {
  font-size: 28rpx;
  color: #ccc;
  margin: 0 8rpx;
}

/* 理由 */
.reason-block {
  margin-bottom: 24rpx;
}

.block-label {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-bottom: 10rpx;
}

.block-text {
  display: block;
  font-size: 28rpx;
  color: #333;
  line-height: 1.7;
}

/* 因素 */
.factors-block {
  padding-top: 20rpx;
  border-top: 1rpx solid #F0F0F0;
  margin-bottom: 20rpx;
}

.factors-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.factor-item {
  display: flex;
  align-items: center;
  padding: 10rpx 20rpx;
  background: rgba(255, 140, 0, 0.06);
  border-radius: 12rpx;
  border: 1rpx solid rgba(255, 140, 0, 0.15);
}

.factor-name {
  font-size: 24rpx;
  color: #999;
  margin-right: 10rpx;
}

.factor-val {
  font-size: 26rpx;
  font-weight: 600;
  color: #FF8C00;
}

/* 风险提示 */
.risk-block {
  padding: 16rpx 20rpx;
  background: #FFF8E1;
  border-radius: 12rpx;
  border: 1rpx solid #FFE082;
}

.risk-text {
  font-size: 24rpx;
  color: #F57F17;
  line-height: 1.6;
}
