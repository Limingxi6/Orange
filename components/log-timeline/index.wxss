.log-timeline {
  padding: 0 0 24rpx 0;
}

.timeline-item {
  display: flex;
  align-items: flex-start;
  padding-bottom: 4rpx;
}

.timeline-item:last-child {
  padding-bottom: 0;
}

/* 左侧节点 */
.timeline-node {
  position: relative;
  width: 36rpx;
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.node-dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  background: #FF8C00;
  margin-top: 28rpx;
  box-shadow: 0 0 0 6rpx rgba(255, 140, 0, 0.15);
}

.node-line {
  width: 2rpx;
  flex: 1;
  min-height: 40rpx;
  background: #FF8C00;
  opacity: 0.25;
}

/* 右侧内容 */
.timeline-content {
  flex: 1;
  margin-left: 20rpx;
  margin-bottom: 24rpx;
  padding: 20rpx 24rpx;
  background: #fff;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.timeline-content:active {
  background: #FAFAFA;
}

.log-header {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.log-type {
  font-size: 22rpx;
  padding: 4rpx 14rpx;
  background: rgba(255, 140, 0, 0.12);
  color: #FF8C00;
  border-radius: 8rpx;
  font-weight: 500;
  margin-right: 16rpx;
}

.log-time {
  font-size: 24rpx;
  color: #bbb;
}

.log-content {
  font-size: 28rpx;
  color: #333;
  line-height: 1.65;
  display: block;
}

.log-images {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 16rpx;
}

.log-image {
  width: 140rpx;
  height: 140rpx;
  border-radius: 12rpx;
  background: #f5f5f5;
}

.log-footer {
  margin-top: 12rpx;
  padding-top: 12rpx;
  border-top: 1rpx solid #F5F5F5;
}

.log-operator {
  font-size: 22rpx;
  color: #bbb;
}

.timeline-empty {
  padding: 80rpx 0;
  text-align: center;
  color: #ccc;
  font-size: 28rpx;
}
