.trace-block {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.section {
  margin-bottom: 32rpx;
}

.section:last-child {
  margin-bottom: 0;
}

.section-title {
  margin-bottom: 20rpx;
  padding-bottom: 12rpx;
  border-bottom: 2rpx solid rgba(255, 140, 0, 0.2);
}

.title-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #FF8C00;
}

/* 产品信息区 */
.product-info {
  font-size: 28rpx;
}

.info-row {
  display: flex;
  align-items: flex-start;
  margin-bottom: 16rpx;
  line-height: 1.5;
}

.info-row:last-child {
  margin-bottom: 0;
}

.info-label {
  color: #999;
  flex-shrink: 0;
  width: 160rpx;
}

.info-value {
  color: #333;
  flex: 1;
}

.info-empty {
  padding: 24rpx 0;
  text-align: center;
  color: #999;
  font-size: 26rpx;
}

/* 农事时间线区 */
.timeline-list {
  padding: 0;
}

.timeline-item {
  display: flex;
  align-items: flex-start;
  padding-bottom: 28rpx;
}

.timeline-item:last-child {
  padding-bottom: 0;
}

.timeline-node {
  position: relative;
  width: 32rpx;
  flex-shrink: 0;
}

.node-dot {
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  background: #FF8C00;
  margin-left: 6rpx;
  margin-top: 8rpx;
}

.node-line {
  position: absolute;
  left: 14rpx;
  top: 34rpx;
  bottom: -28rpx;
  width: 2rpx;
  background: #FF8C00;
  opacity: 0.4;
}

.timeline-content {
  flex: 1;
  margin-left: 24rpx;
  padding: 16rpx 20rpx;
  background: #FFFBF5;
  border-radius: 12rpx;
  border-left: 4rpx solid #FF8C00;
}

.timeline-header {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.timeline-time {
  font-size: 24rpx;
  color: #999;
  margin-right: 16rpx;
}

.timeline-type {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  background: rgba(255, 140, 0, 0.15);
  color: #FF8C00;
  border-radius: 8rpx;
}

.timeline-desc {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
  display: block;
}

.timeline-empty {
  padding: 32rpx 0;
  text-align: center;
  color: #999;
  font-size: 26rpx;
}

/* 区块链验证状态区 */
.chain-status {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 24rpx;
  border-radius: 12rpx;
}

.status-verified {
  background: rgba(76, 175, 80, 0.08);
}

.status-failed {
  background: rgba(244, 67, 54, 0.08);
}

.status-pending {
  background: rgba(255, 140, 0, 0.08);
}

.status-icon {
  flex-shrink: 0;
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
  font-size: 40rpx;
  font-weight: bold;
}

.status-verified .status-icon {
  background: #4CAF50;
  color: #fff;
}

.status-failed .status-icon {
  background: #F44336;
  color: #fff;
}

.status-pending .status-icon {
  background: rgba(255, 140, 0, 0.3);
  color: #FF8C00;
}

.icon-check {
  color: #fff;
}

.icon-fail {
  color: #fff;
}

.icon-pending {
  color: #FF8C00;
  font-size: 36rpx;
  letter-spacing: 4rpx;
}

.status-text {
  font-size: 28rpx;
  font-weight: 500;
  margin-bottom: 12rpx;
}

.status-verified .status-text {
  color: #4CAF50;
}

.status-failed .status-text {
  color: #F44336;
}

.status-pending .status-text {
  color: #FF8C00;
}

.tx-id {
  font-size: 22rpx;
  color: #999;
  text-align: center;
  word-break: break-all;
  max-width: 100%;
}

.tx-label {
  color: #999;
}

.tx-value {
  color: #666;
}
